// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  TEAM
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  plan          Plan      @default(FREE)
  dailyCount    Int       @default(0)
  dailyReset    DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  prompts   Prompt[]
  favorites UserFavorite[]
  folders   PromptFolder[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Prompt {
  id              String   @id @default(cuid())
  userId          String?
  category        String
  categoryEmoji   String   @default("✦")
  inputs          Json
  generatedPrompt String   @db.Text
  qualityScore    Int?
  qualityReason   String?
  language        String   @default("English")
  isPublic        Boolean  @default(false)
  shareId         String?  @unique @default(cuid())
  createdAt       DateTime @default(now())

  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  favorites UserFavorite[]
  folders   PromptFolder[] @relation("PromptFolders")
}

model PromptTemplate {
  id          String   @id @default(cuid())
  category    String
  title       String
  description String
  inputs      Json
  usageCount  Int      @default(0)
  rating      Float    @default(0)
  ratingCount Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model PromptFolder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompts   Prompt[] @relation("PromptFolders")
}

model UserFavorite {
  id        String   @id @default(cuid())
  userId    String
  promptId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  @@unique([userId, promptId])
}
