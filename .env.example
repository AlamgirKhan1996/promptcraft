# =============================================
# PROMPTCRAFT — ENVIRONMENT VARIABLES
# Copy this to .env.local and fill in values
# =============================================

# DATABASE (Railway PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/promptcraft?schema=public"

# NEXTAUTH
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# GOOGLE OAUTH (console.cloud.google.com)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ANTHROPIC CLAUDE API (console.anthropic.com)
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# LEMON SQUEEZY (payments - phase 2)
# LEMONSQUEEZY_API_KEY="your-key"
# LEMONSQUEEZY_STORE_ID="your-store-id"
# LEMONSQUEEZY_PRO_VARIANT_ID="your-variant-id"
# LEMONSQUEEZY_TEAM_VARIANT_ID="your-variant-id"
# LEMONSQUEEZY_WEBHOOK_SECRET="your-webhook-secret"

# APP CONFIG
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="PromptCraft"
